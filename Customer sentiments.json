        "messages": {
          "values": [
            {
              "content": "=You are a customer sentiment analyzer. Analyze this customer review and respond ONLY in valid JSON with this exact format:\n{\n  \"sentiment\": \"Positive\" or \"Negative\" or \"Neutral\" or \"Mixed\",\n  \"emotion\": \"one or two words describing the dominant emotion (e.g. frustrated, delighted, indifferent)\",\n  \"key_issue\": \"short phrase summarizing the main point, or 'None' if positive with no issue\",\n  \"urgency\": \"High\" or \"Medium\" or \"Low\"\n}\n\nCustomer review: {{ $json.review_text }}"
            }
          ]
        },
        "options": {}
      },
