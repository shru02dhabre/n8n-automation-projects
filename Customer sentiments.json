    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.content[0].text;\nconst clean = raw.replace(/```json|```/g, '').trim();\nconst parsed = JSON.parse(clean);\n\n// Get the ORIGINAL row data from the Loop node, not from Anthropic's output\nconst original = $('Loop Over Items').item.json;\n\nreturn [{\n  json: {\n    feedback_id: original.feedback_id,\n    customer_name: original.customer_name,\n    review_text: original.review_text,\n    sentiment: parsed.sentiment,\n    emotion: parsed.emotion,\n    key_issue: parsed.key_issue,\n    urgency: parsed.urgency\n  }\n}];"
      },
